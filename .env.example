APP_NAME="ساکنا"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# اگر سایت پشت CDN یا لود بالانسر است (ArvanCloud، Cloudflare، …) این را
# تنظیم کنید، وگرنه لاراول درخواست را HTTP می‌بیند و آدرس‌ها را با http://
# می‌سازد. مقدار * یعنی به همه‌ی پراکسی‌ها اعتماد کن؛ فقط وقتی امن است که
# سرور مستقیم از اینترنت در دسترس نباشد یا فایروال جلوی آن را گرفته باشد.
TRUSTED_PROXIES=
APP_TIMEZONE=Asia/Tehran

APP_LOCALE=fa
APP_FALLBACK_LOCALE=fa
APP_FAKER_LOCALE=fa_IR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Production: MySQL / MariaDB (manage with phpMyAdmin) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=manager
DB_USERNAME=root
DB_PASSWORD=

# --- Local/dev quick start: uncomment to use file-based SQLite instead ---
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Payment gateways (configured per-complex in the panel; these are global fallbacks) ---
PAYMENT_DRIVER=fake
MELLAT_TERMINAL_ID=
MELLAT_USERNAME=
MELLAT_PASSWORD=
SAMAN_MERCHANT_ID=
SAMAN_TERMINAL_ID=

# --- SMS reminders (optional) ---
SMS_DRIVER=log
SMS_API_KEY=
SMS_SENDER=

# --- خرید اشتراک پرو (اختیاری) ---
# این درگاه با درگاه هر مجتمع فرق دارد: پول شارژ به حساب مجتمع می‌رود ولی
# پول اشتراک به حساب سرویس‌دهنده. اگر خالی بماند، دکمه‌ی خرید پیام
# «با پشتیبانی تماس بگیرید» نشان می‌دهد و هیچ پرداختی شروع نمی‌شود.
# مقدار «sandbox» برای آزمودن مسیر بدون بانک واقعی است.
SUBSCRIPTION_GATEWAY=
SUBSCRIPTION_GATEWAY_TERMINAL=
SUBSCRIPTION_GATEWAY_USERNAME=
SUBSCRIPTION_GATEWAY_PASSWORD=
SUBSCRIPTION_SUPPORT_PHONE="۰۲۱-۹۱۰۰۰۰۰۰"

VITE_APP_NAME="${APP_NAME}"
